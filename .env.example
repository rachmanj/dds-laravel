APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Invoice import from PDF/image (OpenRouter). Also accepts OPENROUTER_* without underscore.
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_MODEL=openai/gpt-4o
# OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1
INVOICE_IMPORT_ENABLED=true
# Max upload size for import (kilobytes). Default 51200 = 50 MB. Also raise PHP upload_max_filesize, post_max_size, and web server client_max_body_size to match.
# INVOICE_IMPORT_MAX_FILE_KB=51200
# Scanned PDFs: mistral-ocr (default, paid per page) or cloudflare-ai (free, weaker on scans)
# OPEN_ROUTER_PDF_ENGINE=mistral-ocr
# OPEN_ROUTER_PDF_TIMEOUT=240
# OPEN_ROUTER_PDF_FIRST_PAGE_ONLY=true
# Windows / missing CA: download https://curl.se/ca/cacert.pem and set full path (fixes cURL error 60 for OpenRouter HTTPS).
# OPEN_ROUTER_CAINFO=C:\php\extras\ssl\cacert.pem
# Run extraction in the HTTP request (no queue worker). Use for local dev if QUEUE_CONNECTION=database without a worker.
# INVOICE_IMPORT_EXTRACT_SYNC=false

# Domain assistant (AI chat — same OPEN_ROUTER_API_KEY as invoice import unless you split keys in OpenRouter)
# DOMAIN_ASSISTANT_ENABLED=false
# DOMAIN_ASSISTANT_TOOLS_ENABLED=true
# DOMAIN_ASSISTANT_STREAMING_ENABLED=true
# DOMAIN_ASSISTANT_DAILY_USER_LIMIT=0
# OPEN_ROUTER_CHAT_MODEL=deepseek/deepseek-chat
# OPEN_ROUTER_CHAT_TIMEOUT=120

# Telegram bot — Domain Assistant via DM (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_WEBHOOK_SECRET=generate-a-long-random-string
# TELEGRAM_ASSISTANT_ENABLED=false
# Process assistant in webhook request (default true). Set false and run php artisan queue:work if using database/redis queue.
# TELEGRAM_ASSISTANT_DISPATCH_SYNC=true
# Match web default (Show all records off). Set true + see-all-record-switch to mirror web with Show all on.
# TELEGRAM_ASSISTANT_EXPAND_ALL_LOCATIONS=false
# Webhook URL (after deploy): POST https://your-domain/telegram/webhook/{TELEGRAM_WEBHOOK_SECRET}
# Register with Telegram (HTTPS only — use ngrok URL locally): php artisan telegram:set-webhook --url="https://xxxx.ngrok-free.app"

# solar:price:sync-from-last-pertamina (optional — auto-resolves a user if unset)
# SOLAR_PRICE_SCHEDULER_USER_ID=
# SOLAR_PRICE_SCHEDULER_TIMEZONE=Asia/Makassar
